# === Required ===
# OpenAI API key — needed for embeddings and answer generation.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Postgres with pgvector (local Docker default shown)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/rag_blog

# Redis (local Docker default shown)
REDIS_URL=redis://localhost:6379/0

# === Optional ===
# LLM model for answer generation (default: gpt-4.1-mini)
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# Embedding model (default: text-embedding-3-large, 3072 dimensions)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Blog sitemap URL for bulk ingestion
BLOG_SITEMAP_URL=https://cognitiontoday.com/sitemap.xml

# Flask secret key (change in production)
SECRET_KEY=dev-secret

# === RAG tuning (defaults are sensible, override if needed) ===
# RAG_VECTOR_TOP_K=30
# RAG_LEXICAL_TOP_K=20
# RAG_RERANK_TOP_K=8
# RAG_FINAL_CONTEXT_K=5
# RAG_SCORE_THRESHOLD=0.015
